flowchart LR
    User([User])
    Admin([Admin/User])

    subgraph Edge["Azure Front Door + WAF"]
        FD["Main endpoint<br/>(OpenWebUI)"]
        FDA["Admin endpoint<br/>(admin UI)"]
    end

    subgraph Tenant["Client Entra ID Tenant"]
        AAD["Entra ID — OIDC SSO"]
    end

    subgraph Azure["Azure Subscription (per client) — Hub-Spoke VNet"]

        subgraph Spoke["Spoke VNet (private)"]

            subgraph ACA["Container Apps Environment (internal LB)"]
                OWUI["OpenWebUI v0.9.1"]
                LITELLM["LiteLLM proxy<br/>(azure_ai/claude-* + azure/openai)<br/>config rendered per-client"]
                LF["Langfuse — self-hosted<br/>(always on)"]
                ADMIN["admin UI — optional<br/>(Vite+React+Express, TS)"]
                DIGEST[/"digest worker (Job) — optional<br/>tool-calling Claude Haiku 4.5 agent"/]
                RAG[/"RAG ingestion (Job) — optional<br/>chunk → embed → pgvector"/]
            end

            PG[("Postgres Flexible Server<br/>pgvector · rag_chunks · user_preferences")]
            BLOB[("Blob Storage (CMK, PE)<br/>openwebui-uploads · rag-sources")]
            KV[("Key Vault<br/>incl. persisted WEBUI_SECRET_KEY")]

            subgraph Foundry["Azure AI Foundry (per-client subset)"]
                AIHUB["Foundry hub + project"]
                AIS["AI Services account"]
                CLAUDE["Claude Sonnet 4.5 + Haiku 4.5<br/>(MaaS serverless endpoints)"]
                AOAI["GPT-4o / GPT-4o-mini<br/>(Azure OpenAI deployments)"]
                EMBED["text-embedding-3-large<br/>(Azure OpenAI deployment)"]
            end

            ACS["Communication Services Email — optional<br/>(digest delivery)"]
            CS["AI Content Safety"]
        end

        subgraph Hub["Hub VNet"]
            FW["Azure Firewall — egress"]
        end

        subgraph Ops["Platform / Ops"]
            LAW["Log Analytics + App Insights"]
            ACR["Azure Container Registry"]
            DEF["Defender for Cloud + Policy"]
        end
    end

    User -->|HTTPS| FD
    Admin -->|HTTPS| FDA
    FD -->|Private Link| OWUI
    FDA -->|Private Link| ADMIN

    OWUI -. OIDC .-> AAD
    ADMIN -. OIDC + JWT .-> AAD

    OWUI --> PG
    OWUI --> BLOB
    OWUI -->|chat + RAG + title-gen<br/>OpenAI-compatible| LITELLM

    ADMIN --> PG
    ADMIN -->|traces API| LF

    LITELLM -->|azure_ai/claude-*| CLAUDE
    LITELLM -->|azure/gpt-*| AOAI
    LITELLM -->|azure/embedding| EMBED
    LITELLM --> CS
    LITELLM -->|traces| LF

    DIGEST --> PG
    DIGEST -->|agent + tools| LITELLM
    DIGEST -->|Langfuse API| LF
    DIGEST -->|send| ACS

    RAG --> BLOB
    RAG --> PG
    RAG -->|embed| LITELLM

    OWUI -. Managed Identity .-> KV
    LITELLM -. Managed Identity .-> KV
    ADMIN -. Managed Identity .-> KV
    DIGEST -. Managed Identity .-> KV
    RAG   -. Managed Identity .-> KV

    ACA -->|egress| FW
    ACA --> LAW
    ACR -->|image pull| ACA
    DEF -.-> Azure

