<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Your {{ window }} AI assistant summary</title>
</head>
<body style="font-family: -apple-system, Segoe UI, Helvetica, Arial, sans-serif; color: #1f2937; max-width: 620px; margin: 0 auto; padding: 24px;">
  <h2 style="color: #0078D4; margin-bottom: 8px;">Hi {{ name }},</h2>
  <p style="margin-top: 0;">Here's a short recap of your activity over the last {{ window }}.</p>

  <div style="background: #F3F7FB; border-radius: 8px; padding: 16px 20px; margin: 16px 0;">
    {{ summary_html }}
  </div>

  <table cellpadding="0" cellspacing="0" style="font-size: 14px; color: #4b5563;">
    <tr><td>Conversations:</td><td style="padding-left: 12px;"><b>{{ stats.trace_count }}</b></td></tr>
    <tr><td>Tokens used:</td><td style="padding-left: 12px;"><b>{{ '{:,}'.format(stats.total_tokens) }}</b></td></tr>
    {% if stats.top_models %}
    <tr><td>Top models:</td><td style="padding-left: 12px;">
      {%- for name, count in stats.top_models -%}
        {{ name }} ({{ count }}){% if not loop.last %}, {% endif %}
      {%- endfor -%}
    </td></tr>
    {% endif %}
  </table>

  <hr style="margin-top: 32px; border: none; border-top: 1px solid #e5e7eb;" />
  <p style="font-size: 12px; color: #6b7280;">
    You're receiving this because digest emails are enabled for your account.
    <a href="{{ unsub_url }}">Unsubscribe</a>.
  </p>
</body>
</html>
