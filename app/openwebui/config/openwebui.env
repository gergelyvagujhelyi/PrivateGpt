# Non-secret baseline config. Secrets are injected by Container Apps via Key Vault refs.
WEBUI_AUTH=true
ENABLE_OAUTH_SIGNUP=true
OAUTH_PROVIDER_NAME=Microsoft
OAUTH_SCOPES=openid email profile

RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.2
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

ENABLE_ADMIN_EXPORT=false
ENABLE_ADMIN_CHAT_ACCESS=false
